DISCORD_TOKEN=put-your-bot-token-here

# Optional: set this while developing so slash commands update immediately in one server.
# Leave it blank for global command sync.
DEV_GUILD_ID=

# Optional: force one text channel to be used for message-based music requests.
# Usually you can leave this blank and run /setupmusic in Discord instead.
MUSIC_CHANNEL_ID=

# Optional: channel name created by /setupmusic when no existing channel is selected.
MUSIC_CHANNEL_NAME=music

# Optional: send bot replies in the music request channel as silent Discord messages.
MUSIC_CHANNEL_SILENT=true

# Optional: delete a user's song request message after it is queued successfully.
MUSIC_CHANNEL_DELETE_REQUESTS=true

# Optional: delete temporary queue-added feedback messages after this many seconds.
MUSIC_FEEDBACK_DELETE_SECONDS=10

# Optional: cookies for content that requires a signed-in account.
# Cookies do not remove rate limits; never commit this file or use a primary account.
# YOUTUBE_COOKIES_FILE=./cookies.txt

# Optional: yt-dlp timeout, concurrency, global request spacing, and in-memory cache.
YTDL_EXTRACT_TIMEOUT_SECONDS=45
YTDL_MAX_CONCURRENT_EXTRACTIONS=1
YTDL_MIN_INTERVAL_SECONDS=6
YTDL_CACHE_TTL_SECONDS=600
YTDL_CACHE_MAX_ENTRIES=128

# Optional: stop all new YouTube requests for this many seconds after a 429/bot check.
YOUTUBE_CIRCUIT_BREAKER_SECONDS=1800

# Optional: refresh a queued signed stream URL after this many seconds.
STREAM_URL_MAX_AGE_SECONDS=900

# Optional: maximum number of tracks added from an album or playlist at once.
MAX_BULK_TRACKS=50

# Optional: default and maximum number of related tracks added by auto:.
DEFAULT_AUTO_TRACKS=8
MAX_AUTO_TRACKS=25

# Optional: bypass YouTube and replay a local audio file for Discord integration tests.
# Generate one with: ffmpeg -f lavfi -i "sine=frequency=440:duration=15" test-tone.wav
# MUSIC_TEST_AUDIO_FILE=./test-tone.wav
MUSIC_TEST_BULK_TRACKS=3

# Optional: bot output volume from 0.0 to 1.0.
# Roughly maps to Discord's 0-100 normal user volume scale: 0.2 is about 20.
# This is the shared starting volume. Each listener can still adjust the bot locally in Discord.
BOT_VOLUME=0.2

# Optional: use this if ffmpeg is not on PATH.
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe

# Optional: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
